NODE_ENV=production
PORT=3333

# Postgres connection string from Vercel/Neon/Supabase/etc.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# Public API URL used by Better Auth, for example https://api.example.com.
BETTER_AUTH_URL=

# Generate a strong random value and keep it only in the deployment secret store.
BETTER_AUTH_SECRET=

# Comma-separated browser origins allowed to call the API with CORS.
# Native mobile requests normally do not send Origin, but web clients do.
CORS_ORIGINS=https://app.example.com

# Abuse controls. Tune per deployment size and traffic profile.
MAX_BODY_BYTES=32768
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
